# =============================================================================
# Pivot — Environment Configuration Template
# =============================================================================
# Copy this file to `.env` and fill in real values there.
# `.env` must NEVER be committed — only this template is checked into git.
# Loaded by: common/config/settings.py (Phase 0).
# Ground rule #8 (docs/pivot-build-plan.md): secrets never hardcoded, never logged.
# =============================================================================

# --- LiveKit (media transport, data plane) — Phase 1 ---
# Backs services/media-gateway. Corrected ports: in-audio-client, out-audio-client,
# out-audio-stt, in-audio-tts, out-events.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Deepgram Nova-3 STT — Phase 1 ---
# Corrected wiring: livekit.out-audio-stt -> deepgram.in-audio -> deepgram.out-transcript -> orchestrator.in-transcript
DEEPGRAM_API_KEY=

# --- Cartesia Sonic TTS — Phase 1 (audio), Phase 3 (in-tts-ctrl kill signal), Phase 5 (out-word-ts) ---
CARTESIA_API_KEY=

# --- LLM inference: Groq primary, OpenAI fallback — Phase 1 (primary), Phase 7 (fallback + persona parity) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
OPENAI_API_KEY=
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# --- Redis — Phase 2 (session/turn state), Phase 6 (job queue), Phase 7 (semantic cache) ---
REDIS_URL=redis://localhost:6379/0

# --- Qdrant (RAG / knowledge base) — Phase 8, feature-flagged per ground rule #11 ---
QDRANT_URL=
QDRANT_API_KEY=
RAG_ENABLED=false

# --- Enkrypt (output safety guardrails) — Phase 8, feature-flagged ---
ENKRYPT_API_KEY=
ENKRYPT_ENABLED=false

# --- Mastra (tool-calling agent framework) — Phase 8, feature-flagged, ONLY if Phase 6's
#     hand-rolled tool-call FSM proves insufficient. See "Open Decisions" in the build plan.
MASTRA_API_KEY=
MASTRA_ENABLED=false

# --- Secrets Manager backing store — Phase 0 stub (local), Phase 10 hardened ---
SECRETS_BACKEND=local   # local | vault | aws-secrets-manager

# --- Observability — Phase 9 ---
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_PUSHGATEWAY_URL=
LOKI_URL=

# --- App-wide ---
LOG_LEVEL=INFO
ENV=development
SESSION_ID_HEADER=x-pivot-session-id
